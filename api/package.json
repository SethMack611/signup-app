{
  "name": "signup-api",
  "version": "1.0.0",
  "description": "Express API for the Signup Form app with DynamoDB",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --runInBand --forceExit"
  },
  "dependencies": {
    "aws-sdk": "^2.1502.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "testEnvironmentOptions": {
      "env": { "NODE_ENV": "test" }
    }
  }
}
